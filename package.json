{
  "name": "casino",
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,blue \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --bun run --hot src/index.ts",
    "dev:client": "bun run --cwd client dev",
    "db:gen": "bun run drizzle-kit generate",
    "db:push": "bun run drizzle-kit push",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun run dist/index.js",
    "types": "bunx tsc --noEmit",
    "types:check": "concurrently -n server,client \"bun run types\" \"bun run --cwd client types\"",
    "d:build": "docker build -t casino .",
    "d:runp": "docker run --rm -p 0.0.0.0:3000:3000 --env-file .env casino",
    "d:run": "docker run --rm -p 3000:3000 --env-file .env casino",
    "d:dev": "docker build -t casino . && docker run --rm -p 3000:3000 --env-file .env casino"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "expense-tracker": ".",
    "hono": "^4.12.9",
    "hono-rate-limiter": "^0.5.3",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/ioredis": "^5.0.0",
    "@types/pg": "^8.20.0",
    "baseline-browser-mapping": "^2.10.12",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
